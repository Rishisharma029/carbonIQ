# ─── Server ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────
# MongoDB Atlas connection string (use 127.0.0.1 for local dev)
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/carboniq?retryWrites=true&w=majority

# ─── JWT Authentication ───────────────────────────────────
# Generate a strong secret: openssl rand -hex 32
JWT_SECRET=replace_with_a_strong_32_byte_hex_secret
JWT_EXPIRES_IN=1h

# ─── SMTP Email (Nodemailer) ──────────────────────────────
# Use Mailtrap for dev: https://mailtrap.io
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_mailtrap_user
SMTP_PASS=your_mailtrap_pass
SMTP_FROM=noreply@carboniq.com

# ─── CORS (Production) ────────────────────────────────────
# Comma-separated list of allowed frontend origins
# ALLOWED_ORIGINS=https://app.carboniq.com,https://www.carboniq.com
